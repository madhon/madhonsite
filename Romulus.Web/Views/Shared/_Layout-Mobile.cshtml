@inherits Nancy.ViewEngines.Razor.NancyRazorViewBase<dynamic>
@using System
@using Romulus.Web.Constants
@using Romulus.Web.Helpers
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="dns-prefetch" href="https://ajax.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://code.getmdl.io">
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com">
    <title>@Model.Page.PreFixTitle @Model.Page.Title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0" />
    <!--IOS Metadata-->
    <meta name="apple-mobile-web-app-title" content="Madhon's Site" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black" />
    <!--Android/Chrome Metadata-->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#5373F4">
    <meta name="mobile-web-app-capable" content="yes">
    <!--Windows 7/8/8.1 Metadata-->
    <meta name="application-name" content="Madhon's Site" />
    <meta name="msapplication-TileColor" content="#5373F4">
    <meta name="msapplication-config" content="/browserconfig.xml"/>
    @Html.CssTag(@ContentDeliveryNetwork.GetMdl.MdlIconsUrl)
    @Html.CssTag(@ContentDeliveryNetwork.GetMdl.MdlCssUrl)
    @RenderSection("cssFiles", false)
</head>
<body>

    <div class="mdl-layout mdl-js-layout mdl-layout--fixed-drawer mdl-layout--fixed-header">
        <header class="mdl-layout__header">
            <div class="mdl-layout__header-row">
                <!-- Title -->
                <span class="mdl-layout-title">Madhon</span>
                <!-- Add spacer, to align navigation to the right -->
                <div class="mdl-layout-spacer"></div>
            </div>
        </header>
        <div class="mdl-layout__drawer mdl-color--blue-grey-900 mdl-color-text--blue-grey-50">
            <span class="mdl-layout-title">Madhon</span>
            <nav class="mdl-navigation">
                <a class="mdl-navigation__link" href="/">Home</a>
                <a class="mdl-navigation__link" href="/contact">Contact</a>
            </nav>
        </div>
        <main class="mdl-layout__content">
            @RenderBody()
        </main>
    </div>

    <footer class="mdl-mini-footer">
        <div class="mdl-mini-footer__left-section">
            <div class="mdl-logo">Copyright &copy; @DateTime.Now.Year Madhon</div>
        </div>
    </footer>

@Html.JsTag(@ContentDeliveryNetwork.Google.JQuery2Url)
@Html.JsTag(@ContentDeliveryNetwork.GetMdl.MdlJsUrl)
@Html.JsTag("/content/js/app-mobile.js")
@RenderSection("scriptFiles", false)

<script>
  (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
  (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
  m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
  })(window,document,'script','https://www.google-analytics.com/analytics.js','ga');

  ga('create', 'UA-91688909-1', 'auto');
  ga('send', 'pageview');

</script>
</body>
</html>
