@using Romulus.Web.Constants
@using Romulus.Web.Helpers
@{
    Layout = "Shared/_Layout-Mobile.cshtml";
    ViewBag.Title = "Contact";
}

<h2>Contact</h2>

<form action="/Contact" class="col s12" id="frmContact" method="post" name="frmContact" role="form">
@Html.AntiForgeryToken()
    <div class="mdl-grid">
        <div class="mdl-textfield mdl-js-textfield">
            <input class="mdl-textfield__input" id="Name" name="Name" type="text" placeholder="Your Name" value="" autofocus required>
            <label class="mdl-textfield__label" for="Name">Text...</label>
        </div>
    </div>

    <div class="mdl-grid">
        <div class="mdl-textfield mdl-js-textfield">
            <input class="mdl-textfield__input" id="Email" name="Email" type="email" placeholder="Your Email Address" value="" data-parsley-trigger="change" required>
            <label class="mdl-textfield__label" for="Email">Text...</label>
        </div>
    </div>

    <div class="mdl-grid">
        <div class="mdl-textfield mdl-js-textfield">
            <textarea class="mdl-textfield__input" type="text" rows="3" id="Message" placeholder="Your Message" required></textarea>
            <label class="mdl-textfield__label" for="Message">Message</label>
        </div>
    </div>

    <div class="mdl-grid">
        <div class="mdl-cell mdl-cell--1-col"></div>
        <div class="mdl-cell mdl-cell--1-col">
            <button class="mdl-button mdl-js-button mdl-button--raised mdl-button--colored" type="submit" name="SubmitBtn">Submit</button>
        </div>
        <div class="mdl-cell mdl-cell--4-col"></div>
    </div>

    <div class="mdl-grid">
        <div class="mdl-cell mdl-cell--1-col"></div>
        <div class="mdl-cell mdl-cell--1-col">
            <button class="mdl-button mdl-js-button mdl-button--raised mdl-button--accent" type="reset" name="ResetBtn">Reset</button>
        </div>
        <div class="mdl-cell mdl-cell--4-col"></div>
    </div>

</form>


@section scriptFiles {
    @Html.JsTag(ContentDeliveryNetwork.Cloudflare.ParsleyUrl)
    @Html.JsTag("/Content/js/contact.js")
}
