@using System
@using Romulus.Web.Constants
@{
    Layout = "Shared/_Layout.cshtml";
    ViewBag.Title = "Contact";
}

<h2>Contact</h2>
<form action="/Contact" class="form-horizontal" id="frmContact" method="post" name="frmContact" role="form" data-parsley-validate>
    @Html.AntiForgeryToken()
    <fieldset>
        <legend>Your Information</legend>
        <div class="form-group">
            <label class="col-md-2 control-label" for="Name">Name</label>
            <div class="col-md-6">
                <input class="form-control" id="Name" name="Name" placeholder="Your Name" type="text" value="" autofocus required/>
            </div>
        </div>

        <div class="form-group">
            <label class="col-md-2 control-label" for="Email">Email</label>
            <div class="col-md-6">
                <input class="form-control" id="Email" name="rmail" placeholder="Your Email Address" type="Email" value="" data-parsley-trigger="change" required/>
            </div>
        </div>

        <div class="form-group">
            <label class="col-md-2 control-label" for="Message">Message</label>
            <div class="col-md-6">
                <textarea class="form-control" cols="100" data-val="true" data-val-required="Enter your message" id="Message" name="Message" placeholder="Your message" rows="5" required></textarea>
            </div>
        </div>
    </fieldset>
    <div class="form-actions">
        <button class="btn btn-primary" type="submit">Send Message</button>
        <button class="btn btn-danger" type="reset">Cancel</button>
    </div>
</form>

@section scriptFiles {
    <script type="text/javascript" src="@ContentDeliveryNetwork.JsDelivr.ParsleyUrl"></script>
    <script src="/Content/js/contact.js"></script>
}
