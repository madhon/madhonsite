@using System
@{
    Layout = "Shared/_Layout.cshtml";
    ViewBag.Title = "Contact";
}

<h2>Contact</h2>
<form action="/Contact" class="form-horizontal" id="frmContact" method="post" name="frmContact" role="form">
    @Html.AntiForgeryToken()
    <fieldset>
        <legend>Your Information</legend>
        <div class="form-group">
            <label class="col-md-2 control-label" for="Name">Name</label>
            <div class="col-md-6">
                <input class="form-control" id="Name" name="Name" placeholder="Your Name" type="Text" value="" autofocus />
                <span class="field-validation-valid help-inline" data-valmsg-for="Name" data-valmsg-replace="true"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="col-md-2 control-label" for="Email">Email</label>
            <div class="col-md-6">
                <input class="form-control" id="Email" name="Email" placeholder="Your Email Address" type="Email" value="" />
                <span class="field-validation-valid help-inline" data-valmsg-for="Email" data-valmsg-replace="true"></span>
            </div>
        </div>

        <div class="form-group">
            <label class="col-md-2 control-label" for="Message">Message</label>
            <div class="col-md-6">
                <textarea class="form-control" cols="100" data-val="true" data-val-required="Enter your message" id="Message" name="Message" placeholder="Your message" rows="5"></textarea>
                <span class="field-validation-valid help-inline" data-valmsg-for="Message" data-valmsg-replace="true"></span>
            </div>
        </div>
    </fieldset>
    <div class="form-actions">
        <button class="btn btn-primary" type="submit">Send Message</button>
        <button class="btn btn-danger" type="reset">Cancel</button>
    </div>
</form>

@section cssFiles
{
    <link href="//cdnjs.cloudflare.com/ajax/libs/jquery.bootstrapvalidator/0.5.3/css/bootstrapValidator.min.css" rel="stylesheet">
}

@section scriptFiles {
    <script type="text/javascript" src="//cdnjs.cloudflare.com/ajax/libs/jquery.bootstrapvalidator/0.5.3/js/bootstrapValidator.min.js"></script>
    <script async src="/Content/js/contact.js"></script>
}