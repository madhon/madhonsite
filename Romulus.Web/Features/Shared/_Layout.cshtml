        </div>
      </div>
      <div class="clearfix"></div>
    </div>
  </div>

  <header>
    <div class="container">
      <div class="row">
        <div class="col-lg-3">
          <div class="logo">
            <div class="logo-image">
            </div>
            <div class="logo-text">
              <h1>Mad<span class="lightblue">Hon</span></h1>
            </div>
            <div class="clearfix"></div>
          </div>
        </div>

        <div class="col-lg-9">
          <div class="navi float-right">
            <div id="ddtopmenubar" class="mattblackmenu">
              <ul>
                <li>
                  <a asp-controller="Home" asp-action="Index" class="blightblue">
                    <!--<i class="fas fa-home"></i>--><svg viewBox="0 0 24 24">
                      <path d="M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z" />
                    </svg>Home
                  </a>
                </li>
                <li>
                  <a asp-controller="Contact" asp-action="Index" class="bblue">
                    <!--<i class="fas fa-envelope"></i>--><svg viewBox="0 0 24 24">
                      <path d="M22 6C22 4.9 21.1 4 20 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6M20 6L12 11L4 6H20M20 18H4V8L12 13L20 8V18Z" />
                    </svg>Contact
                  </a>
                </li>
              </ul>
            </div>
          </div>
          <div class="navis"></div>
          <div class="clearfix"></div>
        </div>
      </div>
    </div>
  </header>

  <div class="clearfix"></div>

  <!-- Content starts -->
  <div class="content">
    <div class="container ">
      <div class="row">
	      <div class="col-lg-8 offset-lg-2">
		      @RenderBody()
	      </div>
        <div class="col-lg-2"></div>
      </div>
    </div>
  </div>
  <!-- Content ends -->

<footer>
	<div class="container">
		<div class="row">
			<div class="col-lg-12">
				<div class="copy text-center">
					<p>Copyright &copy; @DateTime.Now.Year Madhon</p>
				</div>
			</div>
		</div>
		<div class="clearfix"></div>
	</div>
</footer>
    
<BuildVer />

<script type="text/javascript" src="@ContentDeliveryNetwork.Google.JQuery3Url"></script>
  <script type="text/javascript" src="@ContentDeliveryNetwork.UnPkg.Popper"></script>
  <script type="text/javascript" src="@ContentDeliveryNetwork.JsDelivrCdn.BootstrapJsUrl"></script>
  @RenderSection("scriptFiles", false)
  <script type="text/javascript" src="~/content/js/ga.js" asp-append-version="true"></script>
</body>
</html>
