  <link rel="stylesheet" type="text/css" href="~/content/css/site.min.css" asp-append-version="true" />
  <link rel="stylesheet" type="text/css" href="~/content/css/metro.min.css" asp-append-version="true" />
  @RenderSection("cssFiles", false)
</head>
